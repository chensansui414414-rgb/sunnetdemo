.hero{min-height:560rpx;background:#11110f;color:#fff;padding:40rpx;display:flex;flex-direction:column}.top-controls{display:flex;justify-content:space-between;align-items:center;margin-bottom:54rpx;font-size:24rpx}.period-control{display:flex;border:1px solid #3a3a37;border-radius:999rpx;padding:5rpx}.period-control button{min-height:0;line-height:1;background:transparent;color:#777;border-radius:999rpx;font-size:22rpx;padding:15rpx 24rpx;margin:0}.period-control button::after{border:0}.period-control button.selected{background:#f2f2ee;color:#11110f}.eyebrow{font-size:20rpx;color:#777;letter-spacing:3rpx}.title{font-size:92rpx;line-height:.94;font-weight:500;letter-spacing:-5rpx;margin-top:70rpx;white-space:pre-line}.today{margin-top:auto;border-top:1px solid #393936;padding-top:30rpx;display:flex;align-items:flex-end;gap:18rpx;color:#999}.score{font-size:120rpx;color:#fff;line-height:.8;letter-spacing:-8rpx}.content{padding:100rpx 24rpx}.section-label{font-size:19rpx;color:#777;letter-spacing:3rpx}.heading{display:block;font-size:76rpx;line-height:.98;letter-spacing:-4rpx;margin:35rpx 16rpx 70rpx}.hint{display:block;color:#888;font-size:24rpx;margin:20rpx}.card{background:#fff;border-radius:36rpx;padding:44rpx;margin-bottom:20rpx;min-height:500rpx;display:flex;flex-direction:column}.card.active{background:#11110f;color:#fff}.date{font-size:24rpx;color:#888}.card-score{font-size:150rpx;line-height:.8;letter-spacing:-10rpx;margin-top:auto}.level{font-size:38rpx;margin-top:38rpx}.summary{font-size:23rpx;line-height:1.7;color:#888;margin-top:18rpx}.details{display:flex;flex-direction:column;gap:16rpx;border-top:1px solid #444;margin-top:30rpx;padding-top:24rpx;font-size:22rpx;color:#999}
